{
  "name": "pdf-lib-table",
  "version": "2.2.0",
  "description": "table creation add on for pdf-lib",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js"
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "classes/",
    "lib/"
  ],
  "scripts": {
    "test": "node --test",
    "test:types": "tsc -p test/tsconfig.json",
    "dev": "nodemon --watch . --ignore node_modules --ext js,json,md --exec \"yalc push\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nash-browns/pdf-lib-table.git"
  },
  "keywords": [
    "pdf",
    "pdf-lib",
    "table"
  ],
  "author": "Nash Bostwick",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/nash-browns/pdf-lib-table/issues"
  },
  "homepage": "https://github.com/nash-browns/pdf-lib-table#readme",
  "type": "module",
  "peerDependencies": {
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "pdf-lib": "^1.17.1",
    "typescript": "^7.0.2"
  }
}
